{
  "manifest_version": 3,
  "name": "No For You",
  "version": "0.1.4",
  "description": "Keeps X home on Following instead of For you.",
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
